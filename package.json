    "INSTALL_FOR_AGENTS.md",
    "CLAUDE.md",
    "AGENTS.md",
    "llms.txt",
    "VERSION",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "solana",
    "claude",
    "claude-code",
    "codex",
    "cursor",
    "agent-skill",
    "skill",
    "brain",
    "memory",
    "router",
    "web3"
  ],
  "homepage": "https://github.com/Sushant6095/solana-brain",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sushant6095/solana-brain.git"
  },
